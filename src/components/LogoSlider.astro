---
const logos = [
  { src: '/logos/avte.png', alt: 'AVTE' },
  { src: '/logos/iciga.svg', alt: 'ICIGA' },
  { src: '/logos/igape.png', alt: 'IGAPE' },
  { src: '/logos/IR.png', alt: 'IR' },
  { src: '/logos/shearn.png', alt: 'Shearn' },
  { src: '/logos/take.png', alt: 'TAKE' },
  { src: '/logos/testsoposiciones.svg', alt: 'TestOposiciones' },
  { src: '/logos/proxectonos.png', alt: 'Proxectonos', preserveColor: true },
  { src: '/logos/roydisa.jpg', alt: 'Roydisa', preserveColor: true },
  { src: '/logos/academianos.png', alt: 'Academianos' },
];

// Duplicate logos multiple times for smooth infinite scroll with few items
const repeatedLogos = [...logos, ...logos, ...logos, ...logos];
---

<div class="logos">
  <div class="logo_items">
    {repeatedLogos.map((logo) => (
      <div class={`logo-wrapper${logo.preserveColor ? ' logo-wrapper--color' : ''}`}>
        <img src={logo.src} alt={logo.alt} />
      </div>
    ))}
  </div>
  <div class="logo_items" aria-hidden="true">
    {repeatedLogos.map((logo) => (
      <div class={`logo-wrapper${logo.preserveColor ? ' logo-wrapper--color' : ''}`}>
        <img src={logo.src} alt={logo.alt} />
      </div>
    ))}
  </div>
</div>

<style>
  @keyframes slides {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-100%);
    }
  }

  .logos {
    overflow: hidden;
    padding: 40px 0;
    white-space: nowrap;
    position: relative;
    background: #0a0a0a;
  }

  .logos:before,
  .logos:after {
    position: absolute;
    top: 0;
    content: '';
    width: 200px;
    height: 100%;
    z-index: 2;
  }

  .logos:before {
    left: 0;
    background: linear-gradient(to left, rgba(10,10,10,0), rgb(10, 10, 10));
  }

  .logos:after {
    right: 0;
    background: linear-gradient(to right, rgba(10,10,10,0), rgb(10, 10, 10));
  }

  .logo_items {
    display: inline-flex;
    animation: 40s slides infinite linear;
  }

  .logo-wrapper {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 80px;
    width: 200px;
    margin: 0 40px;
    padding: 16px;
    transition: transform 0.3s ease;
  }

  .logo-wrapper:hover {
    transform: scale(1.08);
  }

  .logo_items img {
    max-height: 60px;
    max-width: 160px;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.85;
    transition: opacity 0.3s ease;
  }

  .logo-wrapper:hover img {
    opacity: 1;
  }

  .logo-wrapper--color img {
    filter: none;
    opacity: 1;
    background: #fff;
    border-radius: 6px;
    padding: 6px 10px;
    box-sizing: border-box;
  }

  @media (max-width: 768px) {
    .logos {
      padding: 32px 0;
    }

    .logos:before,
    .logos:after {
      width: 80px;
    }

    .logo-wrapper {
      height: 60px;
      width: 140px;
      margin: 0 24px;
      padding: 12px;
    }

    .logo_items img {
      max-height: 45px;
      max-width: 120px;
    }
  }
</style>
