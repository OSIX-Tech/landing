---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import ServicesShowcase from '../../components/ServicesShowcase.astro';
import AboutUsSection from '../../components/AboutUsSection.astro';
import HomeFAQ from '../../components/HomeFAQ.astro';
import StaticContactSection from '../../components/StaticContactSection.astro';
import LoadingScreen from '../../components/LoadingScreen.astro';
import { getAllServices } from '../../data/services-multilingual';
import { LANGUAGES, type Lang } from '../../utils/languages';

export const prerender = true;

export async function getStaticPaths() {
  return LANGUAGES.map(lang => ({ params: { lang } }));
}

const { lang = 'en' } = Astro.params as { lang: Lang };

// SEO Data
const seoTitle = ({ es: 'OSIX Tech - Consultoría Tecnológica & Desarrollo a Medida con IA', gl: 'OSIX Tech - Consultoría Tecnolóxica & Desenvolvemento a Medida con IA', en: 'OSIX Tech - Technology Consulting & Custom AI Development' }[lang]);

const seoDescription = ({ es: 'OSIX Tech: Desarrollo de software a medida con IA, consultoría de transformación digital y gestión de subvenciones. Tecnología que genera resultados reales para tu empresa.', gl: 'OSIX Tech: Desenvolvemento de software a medida con IA, consultoría de transformación dixital e xestión de subvencións. Tecnoloxía que xera resultados reais para a túa empresa.', en: 'OSIX Tech: Custom AI software development, digital transformation consulting, and innovation grants. Technology that delivers real results for your business.' }[lang]);

// FAQ translations for structured data
const faqTranslations = await import(`../../../public/locales/${lang}.json`);
const ft = (k: string) => faqTranslations.default[k] || k;

// Team members for Person schema (E-E-A-T signals)
const teamPersons = [
  { name: "Pablo Pazos", role: "CTO / Software Architect", linkedin: "https://www.linkedin.com/in/pablo-pazos-parada/" },
  { name: "Mateo Bodenlle", role: "CFO", linkedin: "https://www.linkedin.com/in/mateo-bodenlle-villarino/" },
  { name: "Juan Freire", role: "Backend Engineer", linkedin: "https://www.linkedin.com/in/juan-freire-alvarez/" },
  { name: "David Gutiérrez", role: "Security & AI Backend Engineer", linkedin: "https://www.linkedin.com/in/david-gutierrez-cs/" },
  { name: "Nicolás Corbal", role: "Frontend Engineer", linkedin: "https://www.linkedin.com/in/nicol%C3%A1s-corbal-912929318/" },
  { name: "David M. Raposeiras", role: "DevOps Engineer", linkedin: "https://www.linkedin.com/in/david-manuel-raposeiras-canabal-a95028210/" },
  { name: "Diego Cristóbal", role: "Full Stack Mobile Engineer", linkedin: "https://www.linkedin.com/in/diego-cristobal-andaluz-3a5580304/" },
];

// Collect testimonials from all services for AggregateRating
const allServices = getAllServices(lang);
const testimonials = allServices.map(s => s.testimonial);

// Structured Data — unified @graph
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["Organization", "LocalBusiness"],
      "@id": "https://osix.tech/#organization",
      "name": "OSIX Tech",
      "url": "https://osix.tech",
      "logo": "https://osix.tech/logo_w.png",
      "description": seoDescription,
      "telephone": "+34 648935068",
      "email": "info@osix.tech",
      "foundingDate": "2024",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Santiago del Estero, 2-4 1G",
        "addressLocality": "Santiago de Compostela",
        "addressRegion": "Galicia",
        "postalCode": "15702",
        "addressCountry": "ES"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 42.8782,
        "longitude": -8.5448
      },
      "areaServed": [
        { "@type": "Country", "name": "Spain" },
        { "@type": "AdministrativeArea", "name": "Galicia" }
      ],
      "sameAs": [
        "https://github.com/osixtech",
        "https://linkedin.com/company/osixtech"
      ],
      "knowsAbout": [
        "Artificial Intelligence",
        "Inteligencia Artificial",
        "Intelixencia Artificial",
        "AI Consulting",
        "Consultoría de IA",
        "Consultoría de IA en Galicia",
        "Digital Transformation",
        "Intelligent Agents",
        "Process Automation",
        "IGAPE IA360",
        "Custom Software Development"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "sales",
        "email": "info@osix.tech",
        "telephone": "+34 648935068",
        "availableLanguage": ["English", "Spanish", "Galician"]
      },
      "employee": teamPersons.map(p => ({
        "@type": "Person",
        "name": p.name,
        "jobTitle": p.role,
        "worksFor": { "@id": "https://osix.tech/#organization" },
        "sameAs": [p.linkedin]
      })),
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5",
        "bestRating": "5",
        "ratingCount": String(testimonials.length),
        "reviewCount": String(testimonials.length)
      },
      "review": testimonials.map(t => ({
        "@type": "Review",
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "author": { "@type": "Person", "name": t.author },
        "reviewBody": t.quote
      })),
      "makesOffer": allServices.map(s => ({
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": s.title,
          "description": s.description,
          "url": `https://osix.tech/${lang}/servicios/${s.id}`
        }
      }))
    },
    {
      "@type": "WebSite",
      "@id": "https://osix.tech/#website",
      "name": "OSIX Tech",
      "url": "https://osix.tech",
      "publisher": { "@id": "https://osix.tech/#organization" },
      "inLanguage": ["en", "es", "gl"]
    },
    {
      "@type": "WebPage",
      "@id": `https://osix.tech/${lang}/#webpage`,
      "name": seoTitle,
      "description": seoDescription,
      "url": `https://osix.tech/${lang}/`,
      "inLanguage": lang,
      "dateModified": "2026-04-07",
      "isPartOf": { "@id": "https://osix.tech/#website" },
      "about": { "@id": "https://osix.tech/#organization" },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [{
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": `https://osix.tech/${lang}/`
        }]
      }
    },
    {
      "@type": "FAQPage",
      "@id": `https://osix.tech/${lang}/#faq`,
      "isPartOf": { "@id": `https://osix.tech/${lang}/#webpage` },
      "mainEntity": [
        { "@type": "Question", "name": ft('home.faq.q1'), "acceptedAnswer": { "@type": "Answer", "text": ft('home.faq.a1') } },
        { "@type": "Question", "name": ft('home.faq.q2'), "acceptedAnswer": { "@type": "Answer", "text": ft('home.faq.a2') } },
        { "@type": "Question", "name": ft('home.faq.q3'), "acceptedAnswer": { "@type": "Answer", "text": ft('home.faq.a3') } },
        { "@type": "Question", "name": ft('home.faq.q4'), "acceptedAnswer": { "@type": "Answer", "text": ft('home.faq.a4') } },
        { "@type": "Question", "name": ft('home.faq.q5'), "acceptedAnswer": { "@type": "Answer", "text": ft('home.faq.a5') } },
        { "@type": "Question", "name": ft('home.faq.q6'), "acceptedAnswer": { "@type": "Answer", "text": ft('home.faq.a6') } }
      ]
    }
  ]
};

---

<Layout 
  lang={lang}
  title={seoTitle}
  description={seoDescription}
  pageType="website"
  jsonLd={jsonLd}
>
  <LoadingScreen duration={1000} />
  <section id="hero"><Hero lang={lang} /></section>
  <section id="services"><ServicesShowcase lang={lang} /></section>
  <section id="about-us"><AboutUsSection lang={lang} /></section>
  <section id="faq"><HomeFAQ lang={lang} /></section>
  <section id="contact"><StaticContactSection lang={lang} /></section>
</Layout>

<style>
  #hero {
    margin-bottom: 7.5vh !important;
  }

  .contact-section {
    transform: translateY(100%);
    opacity: 0;
  }

  .contact-section.visible {
    transform: translateY(0);
    opacity: 1;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const contactSection = document.querySelector('.contact-section');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    if (contactSection) {
      observer.observe(contactSection);
    }
  });
</script>